{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kingmans-web",
  "compatibility_date": "2026-05-01",
  "observability": {
    "enabled": false,
    "logs": {
      "enabled": false,
      "persist": false,
      "invocation_logs": false
    },
    "traces": {
      "enabled": false,
      "persist": false
    }
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
